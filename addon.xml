<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="context.kino.pub.strm" name="kino.pub to STRM" version="2.0.0" provider-name="Du">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="video.kino.pub" version="3.6.2"/>
    <import addon="script.module.pysocks" version="1.7.0"/>
    <import addon="script.module.inputstreamhelper" version="0.5.7" optional="true"/>
  </requires>
  
  <extension point="kodi.context.item">
    <menu id="kodi.core.main">
      <item library="context.py">
        <label>zur Bibliothek hinzufügen</label>
        <visible>String.StartsWith(ListItem.Path,plugin://video.kino.pub/)</visible>
      </item>
    </menu>
  </extension>
  
  <extension point="xbmc.service" library="service.py" start="startup" />
  
  <extension point="xbmc.addon.metadata">
    <summary lang="de_DE">Erstellt und synchronisiert .strm Dateien aus kino.pub</summary>
    <platform>all</platform>
  </extension>
</addon>